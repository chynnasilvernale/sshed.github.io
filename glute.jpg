<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Contact Shape Shed for body contouring consultations and questions about our services.">
  <title>Shape Shed | Contact</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>
  <header>
    <div class="container header-wrap">
      <div class="brand">
        <img src="logo.png" alt="Shape Shed Logo" class="logo">
      </div>
      <nav>
        <ul class="nav-list">
          <li><a href="index.html">Home</a></li>
          <li><a href="services.html">Services</a></li>
          <li><a href="before-after.html">Before &amp; After</a></li>
          <li><a href="wellness-tips.html">Wellness Tips</a></li>
          <li><a href="contact.html">Contact</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <main>
    <section class="page-header">
      <div class="container">
        <h1>Contact Us</h1>
        <p>Interested in learning more? Reach out for consultation information or general questions.</p>
      </div>
    </section>

    <section class="contact-form">
      <div class="container">
        <form method="post" action="#">
          <div class="form-group">
            <label for="firstName">First Name *</label>
            <input type="text" id="firstName" name="firstName" required>
          </div>
          <div class="form-group">
            <label for="lastName">Last Name *</label>
            <input type="text" id="lastName" name="lastName" required>
          </div>
          <div class="form-group">
            <label for="email">Email *</label>
            <input type="email" id="email" name="email" required>
          </div>
          <div class="form-group">
            <label for="phone">Phone</label>
            <input type="tel" id="phone" name="phone">
          </div>
          <div class="form-group">
            <label for="service">Service Interest</label>
            <select id="service" name="service">
              <option value="">Select a service</option>
              <option value="emslim-abs">Emslim Abs</option>
              <option value="emslim-glutes">Emslim Glutes</option>
              <option value="consultation">Consultation</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="form-group">
            <label for="message">Message *</label>
            <textarea id="message" name="message" rows="5" required></textarea>
          </div>
          <button type="submit" class="btn btn-primary">Send Message</button>
        </form>
      </div>
    </section>

    <section class="contact-info">
      <div class="container">
        <h2>Get in Touch</h2>
        <div class="info-grid">
          <div class="info-item">
            <h3>Email</h3>
            <p><a href="mailto:info@shapeshed.com">info@shapeshed.com</a></p>
          </div>
          <div class="info-item">
            <h3>Phone</h3>
            <p>(555) 123-4567</p>
          </div>
          <div class="info-item">
            <h3>Location</h3>
            <p>123 Wellness Way<br>City, State 12345</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="container footer-wrap">
      <p>&copy; 2026 Shape Shed. All rights reserved.</p>
      <p><a href="mailto:info@shapeshed.com">info@shapeshed.com</a></p>
    </div>
  </footer>
</body>
</html>